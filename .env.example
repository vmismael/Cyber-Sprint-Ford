# Ford Intelligence — Environment Variables
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis expostas ao client devem usar o prefixo EXPO_PUBLIC_.

# Endpoint base da API mock (placeholder — backend não faz parte do escopo)
EXPO_PUBLIC_API_BASE_URL=https://api.mock.local

# Google Maps API key (necessária para react-native-maps em Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
